<!DOCTYPE html>
<html lang="es">
<head>
    <script src="https://unpkg.com/@worldcoin/idkit-standalone@1.3.0/dist/idkit-standalone.js"></script>
</head>
<body>

    <button id="world-id-button">Verificar con World ID</button>

    <script>
        // Este es el equivalente al "handleVerify" de tu código
        const verifyProof = async (proof) => {
            console.log("Prueba recibida:", proof);
            
            const response = await fetch("https://tu-app-en-render.com/verify", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(proof),
            });

            if (response.ok) {
                alert("¡Verificación de Humanidad Exitosa!");
            } else {
                throw new Error("La validación falló en el servidor");
            }
        };

        // Inicializar el Widget (Equivalente al <IDKitWidget>)
        window.IDKit.init({
            app_id: "app_7686f9027d3e3c0b53d987a3caf1e111", // Tu App ID
            action: "login", // Tu Action ID del portal
            signal: "user_session_001", // El 'signal' que pusiste en tu código
            onSuccess: (result) => {
                // Esto se ejecuta después de que verifyProof tiene éxito
                window.location.href = "buscador2.html";
            },
            handleVerify: verifyProof, // Aquí conectamos la lógica de validación
            verification_level: "device",
        });

        // Evento para abrir el modal al dar clic
        document.getElementById("world-id-button").addEventListener("click", () => {
            window.IDKit.open();
        });
    </script>
</body>
</html>
